<Window x:Class="Savedrake.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:vm="clr-namespace:Savedrake.App.ViewModels"
        Title="Savedrake"
        Icon="savedrake.ico"
        Width="730" Height="720"
        MinWidth="620" MinHeight="540"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource ShellBrush}"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <!-- Borderless window via WindowChrome so native drag / resize / Aero-Snap / shadow are preserved. -->
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="48" ResizeBorderThickness="6" GlassFrameThickness="0,0,0,1" CornerRadius="0" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Show/hide on a bool (first-run welcome vs the tab shell; tooltips/hints). -->
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <!-- Inverse of the above: hides the tab shell while the first-run welcome panel is showing. -->
        <vm:InverseBoolToVisibilityConverter x:Key="NotBoolToVis" />
        <!-- Inverse bool (drives the second backup-name radio) and non-null bool (the "Switch to" enable gate). -->
        <vm:InverseBoolConverter x:Key="NotBool" />
        <vm:NotNullToBoolConverter x:Key="NotNullToBool" />
        <!-- Display-only converters for the Backups + Characters list rows. -->
        <vm:PinnedToBrushConverter x:Key="PinDotBrush" OnKey="AccentGoldBrush" OffKey="TextSecondaryBrush" />
        <vm:PinnedToBrushConverter x:Key="PinNameBrush" OnKey="AccentGoldBrush" OffKey="TextBrush" />
        <vm:PinStatusToPillTextConverter x:Key="PillText" />
        <vm:PinStatusToPillBrushConverter x:Key="PillBrush" />
    </Window.Resources>

    <!-- Outer margin so the espresso shell shows around the content. -->
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- header -->
            <RowDefinition Height="Auto" />   <!-- gold rule -->
            <RowDefinition Height="*" />      <!-- content -->
            <RowDefinition Height="Auto" />   <!-- status bar -->
        </Grid.RowDefinitions>

        <!-- ============================ HEADER (draggable caption) ============================ -->
        <Border Grid.Row="0" Background="{DynamicResource BarBrush}" CornerRadius="10,10,0,0" Padding="12,7">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />   <!-- brand token -->
                    <ColumnDefinition Width="Auto" />   <!-- wordmark + version -->
                    <ColumnDefinition Width="*" />      <!-- drag spacer + playing hint -->
                    <ColumnDefinition Width="Auto" />   <!-- right controls -->
                </Grid.ColumnDefinitions>

                <!-- 40px circular brand mark: the Savedrake dragon clipped into a thin gold-ringed disc. -->
                <Grid Grid.Column="0" Width="40" Height="40" VerticalAlignment="Center">
                    <Ellipse Fill="{DynamicResource CardBrush}" Stroke="{DynamicResource GoldRuleBrush}" StrokeThickness="1.5" />
                    <Ellipse Margin="1.5">
                        <Ellipse.Fill>
                            <ImageBrush ImageSource="savedrake.ico" Stretch="UniformToFill" />
                        </Ellipse.Fill>
                    </Ellipse>
                </Grid>

                <!-- Wordmark in serif gold + small version. -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <TextBlock Text="Savedrake" FontFamily="Georgia, Times New Roman" FontSize="24"
                               Foreground="{DynamicResource WordmarkBrush}" VerticalAlignment="Center">
                        <TextBlock.Resources>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
                            </Style>
                        </TextBlock.Resources>
                    </TextBlock>
                    <TextBlock Text="{Binding AppVersion}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                               VerticalAlignment="Bottom" Margin="8,0,0,5" />
                </StackPanel>

                <!-- "Playing: X" hint, shown only while you're viewing a different character than the one that's live.
                     Empty string renders as nothing. Sits at the start of the draggable spacer column. -->
                <TextBlock Grid.Column="2" Text="{Binding PlayingIndicator}" FontSize="11" FontWeight="SemiBold"
                           Foreground="{DynamicResource SuccessBrush}" VerticalAlignment="Center" Margin="16,0,0,0" />

                <!-- Right-side controls: minimize + close. Clickable (opt out of caption drag). -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button x:Name="MinimizeButton" Content="&#x2014;" Style="{StaticResource CaptionButton}"
                            ToolTip="Minimize" Click="MinimizeButton_Click" />
                    <Button x:Name="CloseButton" Content="&#x2715;" Style="{StaticResource CaptionCloseButton}"
                            ToolTip="Close" Click="CloseButton_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- 1px gold hairline under the header. -->
        <Border Grid.Row="1" Height="1" Background="{DynamicResource GoldRuleBrush}" />

        <!-- ============================ CONTENT: first-run welcome OR the 3-tab shell ============================ -->
        <Grid Grid.Row="2" Margin="0,10,0,0">

            <!-- FIRST-RUN: shown in place of the whole tab shell until both folders are configured. Reuses the existing
                 detect/browse commands. The buttons here are intentionally NOT ConfigEditable-gated (onboarding). -->
            <Border Style="{StaticResource CardBorder}" VerticalAlignment="Top"
                    Visibility="{Binding NeedsSetup, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="Welcome to Savedrake"
                               FontFamily="Georgia, Times New Roman" FontSize="20"
                               Foreground="{DynamicResource AccentGoldBrush}" Margin="0,2,0,6" />
                    <TextBlock Text="Let's find your Dragon's Dogma 2 saves and pick a safe place to keep your backups. This only takes a moment."
                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13"
                               TextWrapping="Wrap" Margin="0,0,0,16" />

                    <TextBlock Text="1. Your save game folder" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}" Margin="0,0,0,6" />
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding SaveDir}" IsReadOnly="True"
                                 VerticalContentAlignment="Center" Padding="8,6" FontSize="12"
                                 Background="{DynamicResource InputBrush}" Foreground="{DynamicResource TextBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" />
                        <Button Grid.Column="1" Content="Find it for me" Style="{StaticResource PrimaryButton}"
                                Padding="14,6" Margin="8,0,0,0" Command="{Binding DetectSaveFolderCommand}" />
                        <Button Grid.Column="2" Content="Browse" Style="{StaticResource OutlineButton}"
                                Padding="14,6" Margin="8,0,0,0" Command="{Binding BrowseSaveCommand}" />
                    </Grid>

                    <TextBlock Text="2. Where to keep your backups" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}" Margin="0,0,0,6" />
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding BackupDir}" IsReadOnly="True"
                                 VerticalContentAlignment="Center" Padding="8,6" FontSize="12"
                                 Background="{DynamicResource InputBrush}" Foreground="{DynamicResource TextBrush}"
                                 BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" />
                        <Button Grid.Column="1" Content="Choose folder" Style="{StaticResource OutlineButton}"
                                Padding="14,6" Margin="8,0,0,0" Command="{Binding BrowseBackupCommand}" />
                    </Grid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="I'll do this later" Style="{StaticResource OutlineButton}"
                                Padding="14,8" Margin="0,0,8,0" Command="{Binding SkipSetupCommand}" />
                        <Button Content="Start using Savedrake" Style="{StaticResource PrimaryButton}"
                                Padding="16,8" Command="{Binding CompleteSetupCommand}"
                                IsEnabled="{Binding IsConfigured}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- NORMAL: the 3-tab shell, shown once setup is done or skipped. -->
            <TabControl x:Name="MainTabs" Style="{StaticResource AppTabControl}"
                        Visibility="{Binding NeedsSetup, Converter={StaticResource NotBoolToVis}}">

                <!-- ===================== BACKUPS TAB ===================== -->
                <TabItem Header="Backups">
                    <!-- Body gated by IsConfigured: after Skip, the strip, actions and list stay disabled until folders
                         are set (matches the old outer-card gate). -->
                    <Grid IsEnabled="{Binding IsConfigured}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />   <!-- character strip -->
                            <RowDefinition Height="Auto" />   <!-- title + actions -->
                            <RowDefinition Height="*" />      <!-- list: the only scroll region -->
                        </Grid.RowDefinitions>

                        <!-- Row 0: character strip. One-click switching via the ComboBox; "Manage" jumps to Characters. -->
                        <Border Grid.Row="0" Style="{StaticResource CardBorder}" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Character:" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextSecondaryBrush}" />
                                <ComboBox Grid.Column="1" x:Name="CharacterCombo" Margin="8,0,0,0" MinWidth="160"
                                          ItemsSource="{Binding Characters}"
                                          SelectedItem="{Binding SelectedCharacter, Mode=TwoWay}"
                                          DisplayMemberPath="Name"
                                          SelectionChanged="CharacterCombo_SelectionChanged"
                                          ToolTip="Switch which character's backups you're managing. Each character keeps its own backups." />
                                <TextBlock Grid.Column="2" Text="{Binding PlayingIndicator}" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource SuccessBrush}" VerticalAlignment="Center" Margin="12,0,0,0" />
                                <Button Grid.Column="3" Content="Manage…" Style="{StaticResource OutlineButton}"
                                        Padding="12,5" Click="GoToCharactersTab_Click"
                                        ToolTip="See all your characters, add a new one, or rename one" />
                            </Grid>
                        </Border>

                        <!-- Row 1: title + actions. -->
                        <Grid Grid.Row="1" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding BackupsTitle}" Style="{StaticResource SectionTitle}"
                                       Margin="0" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Content="Back up now" Style="{StaticResource PrimaryButton}"
                                        Padding="14,7" Command="{Binding BackupCommand}" />
                                <Button Content="Load into game" Style="{StaticResource PrimaryButton}"
                                        Padding="14,7" Margin="8,0,0,0" Command="{Binding LoadIntoGameCommand}"
                                        ToolTip="Replace your live DD2 save with this character's newest backup (your current character is backed up first)" />
                                <Button Content="Restore" Style="{StaticResource OutlineButton}"
                                        Padding="14,7" Margin="8,0,0,0" Command="{Binding RestoreCommand}"
                                        CommandParameter="{Binding SelectedItems, ElementName=BackupList}" />
                                <Button Content="Undo last restore" Style="{StaticResource OutlineButton}"
                                        Padding="14,7" Margin="8,0,0,0" Command="{Binding UndoLastRestoreCommand}"
                                        ToolTip="Put your live DD2 save back the way it was right before your last restore or load." />
                                <Button Content="Delete" Style="{StaticResource DangerButton}"
                                        Padding="14,7" Margin="8,0,0,0" Command="{Binding DeleteCommand}"
                                        CommandParameter="{Binding SelectedItems, ElementName=BackupList}" />
                            </StackPanel>
                        </Grid>

                        <!-- Row 2: the Backups list. Its own vertical scrollbar is the single scroll region. -->
                        <ListView Grid.Row="2" x:Name="BackupList" ItemsSource="{Binding Backups}"
                                  SelectedItem="{Binding SelectedBackup, Mode=TwoWay}"
                                  SelectionMode="Extended"
                                  KeyDown="BackupList_KeyDown"
                                  MouseDoubleClick="BackupList_MouseDoubleClick"
                                  Background="{DynamicResource CardBrush}"
                                  BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                  Foreground="{DynamicResource TextBrush}"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListView.Resources>
                                <Style TargetType="GridViewColumnHeader">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </Style>
                            </ListView.Resources>

                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="BorderThickness" Value="0,0,0,1" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource RowSepBrush}" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListViewItem">
                                                <Border x:Name="bd" Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}">
                                                    <ContentPresenter VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="{DynamicResource CardAltBrush}" />
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="{DynamicResource SelectionBrush}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListView.ItemContainerStyle>

                            <ListView.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Rename"
                                              Command="{Binding PlacementTarget.DataContext.RenameCommand,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    <MenuItem Header="{Binding PlacementTarget.DataContext.PinMenuLabel,
                                                      RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              Command="{Binding PlacementTarget.DataContext.PinCommand,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    <Separator />
                                    <MenuItem Header="Delete"
                                              Command="{Binding PlacementTarget.DataContext.DeleteCommand,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.SelectedItems,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    <Separator />
                                    <MenuItem Header="Validate all"
                                              Command="{Binding PlacementTarget.DataContext.ValidateAllCommand,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                </ContextMenu>
                            </ListView.ContextMenu>

                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="10,9">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />  <!-- dot -->
                                            <ColumnDefinition Width="*" />     <!-- file name -->
                                            <ColumnDefinition Width="Auto" />  <!-- pill -->
                                            <ColumnDefinition Width="Auto" />  <!-- friendly time -->
                                        </Grid.ColumnDefinitions>

                                        <Ellipse Grid.Column="0" Width="8" Height="8" VerticalAlignment="Center"
                                                 Margin="0,0,10,0"
                                                 Fill="{Binding IsPinned, Converter={StaticResource PinDotBrush}}" />

                                        <TextBlock Grid.Column="1" Text="{Binding FileName}" VerticalAlignment="Center"
                                                   FontSize="13" TextTrimming="CharacterEllipsis"
                                                   Foreground="{Binding IsPinned, Converter={StaticResource PinNameBrush}}" />

                                        <Border Grid.Column="2" Margin="10,0" Padding="8,2" CornerRadius="9"
                                                Background="{DynamicResource InputBrush}" VerticalAlignment="Center">
                                            <TextBlock FontSize="11">
                                                <TextBlock.Text>
                                                    <MultiBinding Converter="{StaticResource PillText}">
                                                        <Binding Path="IsPinned" />
                                                        <Binding Path="Status" />
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                                <TextBlock.Foreground>
                                                    <MultiBinding Converter="{StaticResource PillBrush}">
                                                        <Binding Path="IsPinned" />
                                                        <Binding Path="Status" />
                                                    </MultiBinding>
                                                </TextBlock.Foreground>
                                            </TextBlock>
                                        </Border>

                                        <TextBlock Grid.Column="3" Text="{Binding FriendlyTime}" VerticalAlignment="Center"
                                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextAlignment="Right" MinWidth="80" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </TabItem>

                <!-- ===================== CHARACTERS TAB ===================== -->
                <TabItem Header="Characters">
                    <Grid IsEnabled="{Binding IsConfigured}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />   <!-- title + actions -->
                            <RowDefinition Height="*" />      <!-- list: the only scroll region -->
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Characters" Style="{StaticResource SectionTitle}"
                                       Margin="0" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Content="New character" Style="{StaticResource PrimaryButton}"
                                        Padding="14,7" Command="{Binding NewCharacterCommand}" />
                                <Button Content="Rename" Style="{StaticResource OutlineButton}"
                                        Padding="14,7" Margin="8,0,0,0" Command="{Binding RenameCharacterCommand}"
                                        ToolTip="Rename the current character (the one shown in bold). Its backups move with it." />
                                <Button Content="Switch to" Style="{StaticResource OutlineButton}"
                                        Padding="14,7" Margin="8,0,0,0"
                                        Command="{Binding SwitchCharacterCommand}"
                                        CommandParameter="{Binding SelectedItem.Name, ElementName=CharacterList}"
                                        Click="SwitchToButton_Click"
                                        IsEnabled="{Binding SelectedCharacter, Converter={StaticResource NotNullToBool}}" />
                                <Button Content="Load into game" Style="{StaticResource PrimaryButton}"
                                        Padding="14,7" Margin="8,0,0,0" Command="{Binding LoadIntoGameCommand}"
                                        ToolTip="Replace your live DD2 save with the current character's newest backup (your current character is backed up first)" />
                            </StackPanel>
                        </Grid>

                        <ListView Grid.Row="1" x:Name="CharacterList" ItemsSource="{Binding Characters}"
                                  SelectedItem="{Binding SelectedCharacter, Mode=TwoWay}"
                                  MouseDoubleClick="CharacterList_MouseDoubleClick"
                                  SelectionMode="Single"
                                  Background="{DynamicResource CardBrush}"
                                  BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                  Foreground="{DynamicResource TextBrush}"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListView.Resources>
                                <Style TargetType="GridViewColumnHeader">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </Style>
                            </ListView.Resources>

                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="BorderThickness" Value="0,0,0,1" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource RowSepBrush}" />
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListViewItem">
                                                <Border x:Name="bd" Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}">
                                                    <ContentPresenter VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="{DynamicResource CardAltBrush}" />
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="bd" Property="Background" Value="{DynamicResource SelectionBrush}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListView.ItemContainerStyle>

                            <ListView.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Switch to"
                                              Command="{Binding PlacementTarget.DataContext.SwitchCharacterCommand,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                              CommandParameter="{Binding PlacementTarget.SelectedItem.Name,
                                                        RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                </ContextMenu>
                            </ListView.ContextMenu>

                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="10,9">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />  <!-- dot -->
                                            <ColumnDefinition Width="*" />     <!-- name -->
                                            <ColumnDefinition Width="Auto" />  <!-- badges -->
                                            <ColumnDefinition Width="Auto" />  <!-- count -->
                                        </Grid.ColumnDefinitions>

                                        <Ellipse Grid.Column="0" Width="8" Height="8" VerticalAlignment="Center"
                                                 Margin="0,0,10,0"
                                                 Fill="{Binding IsActive, Converter={StaticResource PinDotBrush}}" />

                                        <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center"
                                                   FontSize="13" TextTrimming="CharacterEllipsis"
                                                   Foreground="{Binding IsActive, Converter={StaticResource PinNameBrush}}" />

                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Border Padding="8,2" CornerRadius="9" Margin="0,0,6,0"
                                                    Background="{DynamicResource InputBrush}"
                                                    Visibility="{Binding IsActive, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="Current" FontSize="11"
                                                           Foreground="{DynamicResource AccentGoldBrush}" />
                                            </Border>
                                            <Border Padding="8,2" CornerRadius="9"
                                                    Background="{DynamicResource InputBrush}"
                                                    Visibility="{Binding IsPlaying, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="Playing" FontSize="11"
                                                           Foreground="{DynamicResource SuccessBrush}" />
                                            </Border>
                                        </StackPanel>

                                        <TextBlock Grid.Column="3" Text="{Binding CountLabel}" VerticalAlignment="Center"
                                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextAlignment="Right" MinWidth="80" Margin="10,0,0,0" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </TabItem>

                <!-- ===================== SETTINGS TAB ===================== -->
                <!-- NEVER gated by IsConfigured: after Skip-setup this is the only way to reach Folders and finish.
                     The single ScrollViewer is the ONLY scroller in this tab. -->
                <TabItem Header="Settings">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                  Padding="0,0,6,0">
                        <StackPanel>

                            <!-- 1. Folders -->
                            <Border Style="{StaticResource CardBorder}">
                                <StackPanel>
                                    <TextBlock Text="Folders" Style="{StaticResource SectionTitle}" />
                                    <TextBlock Text="Where Savedrake finds your Dragon's Dogma 2 save and keeps your backups. You usually set these once."
                                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" TextWrapping="Wrap" Margin="0,4,0,14" />

                                    <TextBlock Text="Save game folder" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextBrush}" Margin="0,0,0,6" />
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Text="{Binding SaveDir}" IsReadOnly="True" VerticalContentAlignment="Center"
                                                 Padding="8,6" FontSize="12" Background="{DynamicResource InputBrush}"
                                                 Foreground="{DynamicResource TextBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" />
                                        <Button Grid.Column="1" Content="Find it for me" Style="{StaticResource OutlineButton}" Padding="14,6"
                                                Margin="8,0,0,0" Command="{Binding DetectSaveFolderCommand}" IsEnabled="{Binding ConfigEditable}" />
                                        <Button Grid.Column="2" Content="Browse" Style="{StaticResource OutlineButton}" Padding="14,6"
                                                Margin="8,0,0,0" Command="{Binding BrowseSaveCommand}" IsEnabled="{Binding ConfigEditable}" />
                                    </Grid>

                                    <TextBlock Text="Backups folder" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextBrush}" Margin="0,0,0,6" />
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Text="{Binding BackupDir}" IsReadOnly="True" VerticalContentAlignment="Center"
                                                 Padding="8,6" FontSize="12" Background="{DynamicResource InputBrush}"
                                                 Foreground="{DynamicResource TextBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" />
                                        <Button Grid.Column="1" Content="Browse" Style="{StaticResource OutlineButton}" Padding="14,6"
                                                Margin="8,0,0,0" Command="{Binding BrowseBackupCommand}" IsEnabled="{Binding ConfigEditable}" />
                                    </Grid>
                                    <TextBlock Text="{Binding BackupCount, StringFormat={}{0} backups for the current character}"
                                               FontSize="11" Foreground="{DynamicResource TextHintBrush}" Margin="0,0,0,8" />
                                    <TextBlock Text="Folders are locked while automatic backup is turned on. Turn it off to change them."
                                               FontSize="11" Foreground="{DynamicResource TextHintBrush}" TextWrapping="Wrap"
                                               Visibility="{Binding AutobackupEnabled, Converter={StaticResource BoolToVis}}" />
                                </StackPanel>
                            </Border>

                            <!-- 2. Autobackup (disabled until folders are set) -->
                            <Border Style="{StaticResource CardBorder}" IsEnabled="{Binding IsConfigured}">
                                <StackPanel>
                                    <TextBlock Text="Autobackup" Style="{StaticResource SectionTitle}" />
                                    <TextBlock Text="Savedrake watches Dragon's Dogma 2 and quietly saves copies of your game while you play, so a crash or a bad ending can't cost you your progress."
                                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,4" />
                                    <CheckBox Content="Back up automatically while Dragon's Dogma 2 is running"
                                              IsChecked="{Binding AutobackupEnabled}" Margin="0,6,0,0"
                                              ToolTip="When this is on, Savedrake makes backups in the background the whole time the game is open. Turn it off to make backups only by hand." />

                                    <TextBlock Text="When to back up" Margin="20,14,0,0" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextSecondaryBrush}" />
                                    <Grid Margin="20,8,0,0" IsEnabled="{Binding ConfigEditable}" HorizontalAlignment="Left">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Every" VerticalAlignment="Center" Margin="0,0,8,0"
                                                   FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" />
                                        <TextBox Grid.Column="1" Width="120" Text="{Binding IntervalText}"
                                                 VerticalContentAlignment="Center" Padding="8,5" FontSize="12"
                                                 Background="{DynamicResource InputBrush}" Foreground="{DynamicResource TextBrush}"
                                                 BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                                 ToolTip="How often to take a timed backup while you play. This is your safety net if the game crashes before it saves. Type a time like 5 minutes, 30 minutes, 1 hour, or 2 hours. The shortest allowed is 5 minutes." />
                                        <TextBlock Grid.Column="2" Text="(a safety net in case the game crashes mid-session)"
                                                   VerticalAlignment="Center" Margin="10,0,0,0" FontSize="11"
                                                   Foreground="{DynamicResource TextHintBrush}" />
                                    </Grid>
                                    <TextBlock Margin="20,4,0,0" FontSize="11" Foreground="{DynamicResource TextHintBrush}"
                                               Text="Examples: 5 minutes, 30 minutes, 1 hour, 2 hours (minimum 5 minutes)." />
                                    <CheckBox Content="The instant the game saves"
                                              IsChecked="{Binding BackupOnSaveEnabled}" Margin="20,10,0,0"
                                              ToolTip="Also make a backup every time the game writes a save. This catches your latest progress the moment it happens, on top of the timed backups." />
                                    <CheckBox Content="When I close the game"
                                              IsChecked="{Binding BackupOnGameCloseEnabled}" Margin="20,8,0,0"
                                              ToolTip="Make one last backup when you quit Dragon's Dogma 2. This is the safest moment to copy your save, because the game has finished writing to it." />

                                    <TextBlock Text="How many to keep" Margin="20,16,0,0" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextSecondaryBrush}" />
                                    <Grid Margin="20,8,0,0" IsEnabled="{Binding ConfigEditable}" HorizontalAlignment="Left">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Keep at most" VerticalAlignment="Center" Margin="0,0,8,0"
                                                   FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" />
                                        <TextBox Grid.Column="1" Width="56" Text="{Binding MaxBackupsText}"
                                                 VerticalContentAlignment="Center" Padding="8,5" FontSize="12"
                                                 Background="{DynamicResource InputBrush}" Foreground="{DynamicResource TextBrush}"
                                                 BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                                 ToolTip="How many automatic backups to keep for this character. Older ones are removed once you go past this number, so your backup folder doesn't grow forever. Backups you have pinned are always kept and never counted here." />
                                        <TextBlock Grid.Column="2" Text="backups" VerticalAlignment="Center" Margin="8,0,0,0"
                                                   FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" />
                                    </Grid>
                                    <TextBlock Text="Pinned backups are always kept and don't count toward this limit."
                                               Margin="20,4,0,0" FontSize="11" Foreground="{DynamicResource TextHintBrush}" />
                                    <CheckBox Content="Remove the oldest automatic backups once the limit is reached"
                                              IsChecked="{Binding CleanupEnabled}" Margin="20,10,0,0"
                                              ToolTip="When you reach the limit above, let Savedrake remove the oldest automatic backups to make room. Pinned backups are never removed." />
                                    <CheckBox Content="Send removed automatic backups to the Recycle Bin"
                                              IsChecked="{Binding RecycleEnabled}" IsEnabled="{Binding CleanupEnabled}" Margin="44,6,0,0"
                                              ToolTip="Send removed backups to the Recycle Bin instead of deleting them for good, so you can get one back if you change your mind." />
                                </StackPanel>
                            </Border>

                            <!-- 3. Appearance -->
                            <Border Style="{StaticResource CardBorder}">
                                <StackPanel>
                                    <TextBlock Text="Appearance" Style="{StaticResource SectionTitle}" />
                                    <Button Content="{Binding ThemeMenuLabel}" Style="{StaticResource OutlineButton}"
                                            Padding="14,7" HorizontalAlignment="Left" Click="ToggleTheme_Click" />
                                </StackPanel>
                            </Border>

                            <!-- 4. When backups are made (name format + hotkey) -->
                            <Border Style="{StaticResource CardBorder}">
                                <StackPanel>
                                    <TextBlock Text="Backups" Style="{StaticResource SectionTitle}" />
                                    <TextBlock Text="How new backups are named" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextBrush}" Margin="0,0,0,2" />
                                    <RadioButton Content="Random names" Margin="0,8,0,0"
                                                 IsChecked="{Binding UseRandomName, Mode=TwoWay}" />
                                    <RadioButton Content="Date and time names" Margin="0,6,0,0"
                                                 IsChecked="{Binding UseRandomName, Converter={StaticResource NotBool}, Mode=TwoWay}" />

                                    <TextBlock Text="Backup hotkey" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextBrush}" Margin="0,16,0,4" />
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding HotkeyDisplay}" VerticalAlignment="Center" MinWidth="120"
                                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                                        <Button Content="Set backup hotkey…" Style="{StaticResource OutlineButton}" Padding="14,6"
                                                Margin="10,0,0,0" Click="SetHotkey_Click" />
                                    </StackPanel>
                                    <TextBlock Text="Press your hotkey any time to make a backup, even while you're in the game."
                                               FontSize="11" Foreground="{DynamicResource TextHintBrush}" Margin="0,6,0,0" />
                                </StackPanel>
                            </Border>

                            <!-- 5. System tray -->
                            <Border Style="{StaticResource CardBorder}">
                                <StackPanel>
                                    <TextBlock Text="System tray" Style="{StaticResource SectionTitle}" />
                                    <CheckBox Content="Minimize to the system tray instead of the taskbar"
                                              IsChecked="{Binding MinimizeToTray}" Margin="0,2,0,0" />
                                </StackPanel>
                            </Border>

                            <!-- 6. Recovery -->
                            <Border Style="{StaticResource CardBorder}">
                                <StackPanel>
                                    <TextBlock Text="Recovery" Style="{StaticResource SectionTitle}" />
                                    <Button Content="Undo last restore" Style="{StaticResource OutlineButton}" Padding="14,7"
                                            HorizontalAlignment="Left" Command="{Binding UndoLastRestoreCommand}"
                                            ToolTip="Put your live DD2 save back the way it was right before your last restore or load." />
                                </StackPanel>
                            </Border>

                            <!-- 7. Reset -->
                            <Border Style="{StaticResource CardBorder}">
                                <StackPanel>
                                    <TextBlock Text="Reset" Style="{StaticResource SectionTitle}" />
                                    <TextBlock Text="Clear Savedrake's settings and start over. Your backups on disk are not deleted."
                                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13" TextWrapping="Wrap" Margin="0,2,0,8" />
                                    <Button Content="Reset Savedrake…" Style="{StaticResource DangerButton}" Padding="14,7"
                                            HorizontalAlignment="Left" Click="Reset_Click" />
                                </StackPanel>
                            </Border>

                            <!-- 8. About & Help -->
                            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="About &amp; Help" Style="{StaticResource SectionTitle}" />
                                    <WrapPanel>
                                        <Button Content="Check for updates" Style="{StaticResource OutlineButton}" Padding="14,6"
                                                Margin="0,4,8,0" Click="CheckUpdates_Click" />
                                        <Button Content="FAQ" Style="{StaticResource OutlineButton}" Padding="14,6"
                                                Margin="0,4,8,0" Command="{Binding OpenFaqCommand}" />
                                        <Button Content="About" Style="{StaticResource OutlineButton}" Padding="14,6"
                                                Margin="0,4,8,0" Command="{Binding OpenAboutCommand}" />
                                        <Button Content="Open log folder" Style="{StaticResource OutlineButton}" Padding="14,6"
                                                Margin="0,4,8,0" Command="{Binding OpenLogFolderCommand}" />
                                    </WrapPanel>
                                    <TextBlock Text="{Binding AppVersion, StringFormat=Version {0}}"
                                               FontSize="11" Foreground="{DynamicResource TextHintBrush}" Margin="0,10,0,0" />
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

            </TabControl>
        </Grid>

        <!-- ============================ STATUS BAR ============================ -->
        <Border Grid.Row="3" Background="{DynamicResource BarBrush}" CornerRadius="0,0,10,10" Padding="12,6">
            <TextBlock Text="{Binding StatusText}" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}" />
        </Border>
    </Grid>
</Window>
