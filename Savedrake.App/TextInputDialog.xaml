<Window x:Class="Savedrake.App.TextInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        SizeToContent="WidthAndHeight" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False">
    <!-- A small themed text prompt used in place of Microsoft.VisualBasic.Interaction.InputBox so renaming a character
         or a backup matches the app's warm-dark look. Same shell as HotkeyDialog (DynamicResource brushes + shared
         button styles). Enter confirms (Ok is IsDefault), Esc cancels. -->
    <Border Background="{DynamicResource ShellBrush}" BorderBrush="{DynamicResource AccentGoldBrush}"
            BorderThickness="1" CornerRadius="12" Padding="22" Width="430">
        <StackPanel>
            <TextBlock x:Name="TitleText" FontSize="17" FontWeight="SemiBold"
                       Foreground="{DynamicResource AccentGoldBrush}" Margin="0,0,0,8" />
            <TextBlock x:Name="MessageText" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13"
                       TextWrapping="Wrap" Margin="0,0,0,14" />
            <TextBox x:Name="Input" VerticalContentAlignment="Center" Padding="10,8" FontSize="14"
                     Background="{DynamicResource InputBrush}" Foreground="{DynamicResource TextBrush}"
                     CaretBrush="{DynamicResource TextBrush}"
                     BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,18" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Style="{StaticResource OutlineButton}" Padding="14,6" Click="Cancel_Click" />
                <Button x:Name="OkBtn" Content="OK" Style="{StaticResource PrimaryButton}" Padding="18,6"
                        Margin="8,0,0,0" Click="Ok_Click" IsDefault="True" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
